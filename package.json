{
  "name": "codespec",
  "version": "0.1.0",
  "description": "A deterministic behavioral specification language that bridges AI-generated code and human understanding",
  "type": "module",
  "bin": {
    "codespec": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-unknown",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" --ignore-unknown",
    "parse:test": "vitest run --reporter=verbose tests/parser/"
  },
  "keywords": [
    "codespec",
    "specification",
    "static-analysis",
    "code-generation",
    "behavioral-spec"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "peggy": "^4.2.0",
    "php-parser": "^3.2.1",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.19.0",
    "@eslint/js": "^9.19.0",
    "typescript-eslint": "^8.22.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
