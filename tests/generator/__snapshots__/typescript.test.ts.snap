exports[`TypeScript Generator: snapshot > should match snapshot 1`] = `
"// Generated by CodeSpec — do not edit manually

export class EmailAlreadyExistsError extends Error {
  public readonly status = 409;

  constructor(message?: string) {
    super(message ?? "A user with this email already exists");
    this.name = "EmailAlreadyExistsError";
  }
}

export class UserNotFoundError extends Error {
  public readonly status = 404;

  constructor(message?: string) {
    super(message ?? "The requested user was not found");
    this.name = "UserNotFoundError";
  }
}

export class InternalErrorError extends Error {

  constructor(message?: string) {
    super(message ?? "InternalError");
    this.name = "InternalErrorError";
  }
}

export interface UserRegistrationInput {
  email: string;
  password: string;
  nickname?: string;
}

export interface UserRegistrationOutput {
  user: User;
  token: string;
}

export function register(email: string, password: string): User {
  if (CALL userExists(email)) {
    throw new EmailAlreadyExistsError("A user with this email already exists");
  }
  const hashedPassword = CALL hashPassword(password);
  const user = createUser(email, hashedPassword);
  emit("UserRegistered", user);
  return user;
}

export function deleteUser(userId: string, role: string): void {
  switch (role) {
    case "admin": {
      throw new ForbiddenError("Cannot delete admin users");
    }
    case "user": {
      removeUser(userId);
      emit("UserDeleted", userId);
      break;
    }
  }
}
"
`;
